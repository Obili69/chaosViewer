# Required — generate a random secret: openssl rand -hex 64
JWT_SECRET=change_this_to_a_long_random_secret

# Initial admin account (only needed on first start, remove after)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=changeme

# ── Webhook server (for UI-triggered updates) ────────────────────────────────
# Generate: openssl rand -hex 32
WEBHOOK_SECRET=change_this_to_a_random_secret

# ── Backup to NAS (used by scripts/backup.sh) ────────────────────────────────
NAS_HOST=10.1.90.12
NAS_USER=backup-chaosviewer
NAS_PATH=/mnt/DATA/chaosviewer
SSH_KEY=/root/.ssh/chaosviewer_backup   # host path, mounted into container
# KEEP_DAYS=30                               # how many days of backups to keep on NAS
